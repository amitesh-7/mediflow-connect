# Frontend environment variables
# Copy this file to .env and fill in your values.
# Only VITE_ prefixed vars are exposed to the browser bundle.

# Backend API base URL — the Express server running locally or in production.
# Must include the /api prefix; the frontend concatenates paths like /auth/login on top.
# Examples:
#   local dev:  http://localhost:5000/api
#   production: https://api.your-domain.com/api
VITE_API_URL=http://localhost:5000/api
# For production (Vercel) deployments, set this to the deployed backend URL,
# e.g.: https://mediflow-backend.vercel.app/api
