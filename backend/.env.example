# ─────────────────────────────────────────────
# MediFlow Backend — Environment Variables
# ─────────────────────────────────────────────
# Copy this to .env and fill in real values.
# NEVER commit .env to git.

# ── Direct PostgreSQL connection (for all data queries) ──
# Get from: Supabase Dashboard -> Settings -> Database -> Connection string -> URI
# IMPORTANT: URL-encode special chars in password:  # -> %23   @ -> %40
DATABASE_URL=postgresql://postgres.your-project-id:%23YourPass%40word@aws-0-region.pooler.supabase.com:6543/postgres

# ── Supabase Postgres (direct connection — only for data, not auth) ──
# The `auth.users` table is no longer used; we own user identity in `profiles`.
DATABASE_URL=postgresql://postgres.your-project-id:%23YourPass%40word@aws-0-region.pooler.supabase.com:6543/postgres

# ── Server config ──
PORT=5000
# For production (Vercel) deployments, set this to the deployed frontend URL,
# e.g.: https://mediflow-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

# ── JWT signing secret (MediFlow issues its own JWTs) ──
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# ── SMTP (used to send login + signup OTP codes) ──
# For Gmail:
#   1. Enable 2-Step Verification on the Google account
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Use the 16-char app password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="MediFlow <your-email@gmail.com>"

# ── SMTP (used to send password-reset emails) ──
# For Gmail:
#   1. Enable 2-Step Verification on the Google account
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Use the 16-char app password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="MediFlow <your-email@gmail.com>"
